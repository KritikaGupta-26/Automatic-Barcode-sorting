def log_to_cloud(product, dest, lane):
    """
    Sends sorting data to Firebase for logging and MQTT for live dashboarding.
    """
    timestamp = datetime.now().isoformat() [cite: 181]
    
    # Prepare data payload [cite: 182]
    data = {
        "product": product, [cite: 183]
        "destination": dest, [cite: 184]
        "lane": lane, [cite: 185]
        "status": "routed", [cite: 186]
        "timestamp": timestamp [cite: 187]
    }

    # 1. Update Firebase Realtime Database
    ref.push(data) [cite: 267]

    # 2. Publish to MQTT for Live Dashboard Refresh
    # This allows the UI to update instantly without polling the DB
    client.publish("sorting/live_events", str(data)) [cite: 268]
    
    print(f"Cloud Log Successful: {product} to {dest}")